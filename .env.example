# ── LLM ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# ── WhatsApp (Meta Cloud API) ─────────────────────────────
WA_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxx
WA_PHONE_ID=1234567890123456
WA_APP_SECRET=your_app_secret_here
WA_VERIFY_TOKEN=hanuji_verify_secret_2024

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# ── Google APIs ───────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
GOOGLE_REFRESH_TOKEN=1//your-refresh-token

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://hanuji:password@localhost:5432/hanuji
POSTGRES_DB=hanuji
POSTGRES_USER=hanuji
POSTGRES_PASSWORD=password

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Vector DB (Pinecone) ──────────────────────────────────
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX=hanuji-memory

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-character-string-in-production
JWT_EXPIRES_IN=7d

# ── n8n ───────────────────────────────────────────────────
N8N_USER=admin
N8N_PASS=changeme123

# ── App ───────────────────────────────────────────────────
NODE_ENV=development
API_GATEWAY_PORT=3000
AGENT_SERVICE_PORT=3001
WEBHOOK_SERVICE_PORT=3002
FRONTEND_URL=http://localhost:5173
INTERNAL_API_SECRET=internal-service-secret-change-me
